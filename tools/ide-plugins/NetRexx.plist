<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
	"http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">

<!--  The smallest CLM for NetRexx (www.netrexx.org)
      that will color keywords.
      Copyright (c) 2026 piotr Kolasiński
      based on Bare Bones Software, Inc. templates  -->
		
<dict>
	<!-- Identify the plist as a CLM: -->
	<key>BBEditDocumentType</key>
	<string>CodelessLanguageModule</string>
	
	<!-- Identify language: -->
	<key>BBLMLanguageDisplayName</key>
	<string>NetRexx</string>
	<key>BBLMLanguageCode</key>
	<string>nrx</string>
	
	<!-- Simple color syntax based on string definitions -->
	<key>BBLMColorsSyntax</key>
	<true/>
	
	<!-- Keywords. This version iclude all inherited from REXX,
         and some referencing to Java technology -->
	<key>BBLMKeywordList</key>
	<array>
		<string>import</string>
		<string>package</string>
		<string>class</string>
		<string>method</string>
		<string>properties</string>
		<string>catch</string>
		<string>super</string>
		<string>this</string>
		<string>catch</string>
	
		<string>say</string>
		<string>ask</string>
		
		<string>address</string>
		<string>arg</string>

		<string>parse</string>
		<string>interpet</string>
		<string>nop</string>
		
		<string>trace</string>
		<string>go</string>
		<string>loop</string>
		<string>iterate</string>
		<string>exit</string>
		<string>numeric</string>
		<string>signal</string>
		
		<string>options</string>

		<string>leave</string>
		<string>loop</string>
		<string>if</string>
		<string>then</string>
		<string>else</string>
		<string>do</string>
		<string>end</string>
		<string>select</string>
		<string>when</string>
		<string>otherwise</string>
		<string>return</string>
	</array>
	
	<!-- Specify a comment-out string: -->
	<key>BBLMCommentLineDefault</key>   <string>--</string>
	
	<!-- You must specify the character set for
             keywords and identifiers. Substitute your own:  -->
	<key>Language Features</key>
	<dict>
		<key>Identifier and Keyword Character Class</key>
		<string>A-Za-z0-9_\?!</string>
	    <key>Open Strings 1</key>
	    <string>"</string>
		<key>Close Strings 1</key>
		<string>"</string>
	    <key>Open Strings 2</key>
	    <string>'</string>
		<key>Close Strings 2</key>
		<string>'</string>
        <key>Open Block Comments</key>
        <string>/*</string>
        <key>Close Block Comments</key>
        <string>*/</string>
        <key>Open Line Comments</key>
        <string>--</string>
		
	</dict> 
</dict>
</plist>
